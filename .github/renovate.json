{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>SonarSource/renovate-config:ide-xp-team"
  ],
  "postUpgradeTasks": {
    "commands": [
      "./gradlew --write-verification-metadata sha256 help"
    ],
    "fileFilters": [
      "gradle/verification-metadata.xml"
    ],
    "executionMode": "update"
  }
}
